{
  "name": "@Qazzian/pixel-game-engine",
  "version": "0.1.5",
  "description": "Simple game engine inspired by OneLoneCoder",
  "main": "cjs/index.js",
  "module": "esm/index.js",
  "types": "esm/index.d.ts",
  "files": [
    "cjs",
    "esm",
    "src"
  ],
  "type": "module",
  "scripts": {
    "prepare": "npm run build",
    "prebuild": "npm run clean",
    "build": "npm run build:esm && npm run build:cjs",
    "build:esm": "tsc",
    "build:cjs": " npx rollup esm/index.js --file cjs/index.js --format cjs",
    "build:watch": "tsc -w",
    "clean": "rimraf esm cjs",
    "lint": "prettier . --write && eslint .",
    "lint:fix": "eslint . --fix",
    "test": "vitest run",
    "test:watch": "vitest run --watch",
    "prepush": "npm run lint && npm run test -- --color && npm run build",
    "preversion": "build",
    "postVersion": "git push && git push --tags",
    "test:coverage": "vitest run --coverage"
  },
  "author": "Qazzian",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.28.3",
    "@babel/preset-env": "^7.28.3",
    "@babel/preset-typescript": "^7.18.6",
    "@eslint/js": "^9.32.0",
    "@tsconfig/node-lts": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/random-seed": "^0.3.3",
    "@vitest/coverage-v8": "^4.1.1",
    "canvas": "^3.2.0",
    "eslint": "^9.32.0",
    "eslint-plugin-jest": "^29.0.1",
    "html-webpack-plugin": "^5.6.4",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "rollup": "^4.46.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0",
    "vitest": "^4.1.1",
    "vitest-canvas-mock": "^1.1.4"
  },
  "dependencies": {
    "random-seed": "^0.3.0",
    "typescript-event-target": "^1.1.1"
  }
}
