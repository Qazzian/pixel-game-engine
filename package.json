{
	"name": "@Qazzian/pixel-game-engine",
	"version": "0.1.7",
	"description": "Simple game engine inspired by OneLoneCoder",
	"main": "cjs/index.js",
	"module": "esm/index.js",
	"type": "module",
	"types": "esm/index.d.ts",
	"files": [
		"cjs",
		"esm",
		"src"
	],
	"scripts": {
		"prepare": "npm run build",
		"prebuild": "npm run clean",
		"build": "npm run build:esm && npm run build:cjs",
		"build:esm": "tsc",
		"build:cjs": " npx rollup esm/index.js --file cjs/index.js --format cjs",
		"build:watch": "tsc -w",
		"clean": "rimraf esm cjs",
		"lint": "prettier . --write && eslint .",
		"lint:fix": "eslint . --fix",
		"test": "vitest run",
		"test:watch": "vitest run --watch",
		"prepush": "npm run lint && npm run test -- --color && npm run build",
		"preversion": "build",
		"postVersion": "git push && git push --tags",
		"test:coverage": "vitest run --coverage"
	},
	"author": "Qazzian",
	"license": "ISC",
	"devDependencies": {
		"@babel/core": "^7.29.7",
		"@babel/preset-env": "^7.29.7",
		"@babel/preset-typescript": "^7.29.7",
		"@eslint/js": "^10.0.1",
		"@tsconfig/node-lts": "^24.0.0",
		"@types/jsdom": "^21.1.7",
		"@types/random-seed": "^0.3.3",
		"@vitest/coverage-v8": "^4.1.7",
		"canvas": "^3.2.0",
		"eslint": "^10.4.1",
		"eslint-plugin-jest": "^29.15.2",
		"html-webpack-plugin": "^5.6.7",
		"jsdom": "^29.1.1",
		"prettier": "^3.8.3",
		"rimraf": "^6.0.1",
		"rollup": "^4.60.4",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0",
		"vitest": "^4.1.1",
		"vitest-canvas-mock": "^1.1.4"
	},
	"dependencies": {
		"random-seed": "^0.3.0",
		"typescript-event-target": "^1.1.1"
	}
}
